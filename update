# 1. ابحث عن جميع المراجع
grep -r "stampcoin" . --exclude-dir=node_modules --exclude-dir=.git

# 2. استبدل في جميع ملفات الكود
find . -type f \( -name "*.js" -o -name "*.jsx" -o -name "*.html" \) ! -path "./node_modules/*" -exec sed -i 's/stampcoin/ecostamp/g' {} +

# 3. احذف وأعد إنشاء package-lock.json
rm package-lock.json && npm install

# 4. تحقق من التغييرات
git status
