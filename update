# 1. تحقق من الحالة
git status

# 2. أضف الملفات المعدلة
git add .

# 3. اكتب رسالة التحديث
git commit -m "تحديث النطاق من stampcoin.com إلى ecostamp.net"

# 4. أرسل التحديثات
git push origin main
