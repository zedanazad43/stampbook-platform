# ========================================
# نظام الوكيل الذاتي التطوير
# Self-Evolving Agent System - API Keys
# ========================================
# انسخ هذا الملف إلى .env وأضف مفاتيحك الخاصة
# Copy this to .env and add your own keys

# ====== مزودون مجانيون / FREE PROVIDERS ======

# Google Gemini - مجاني بسخاء (60 طلب/دقيقة مجاناً)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDX0qwrCIkAYZETRDcJY_JHZYyNJHX576g

# Groq - سريع جداً ومجاني (LLaMA 3, Mixtral, Gemma)
# https://console.groq.com
GROQ_API_KEY=

# Hugging Face - آلاف النماذج المجانية
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Together AI - نماذج مفتوحة المصدر (5$ رصيد مجاني)
# https://api.together.xyz
TOGETHER_API_KEY=

# Cohere - Command R نموذج مجاني للفردية
# https://dashboard.cohere.com
COHERE_API_KEY=

# Mistral AI - 1$ رصيد مجاني (كافٍ لآلاف الطلبات)
# https://console.mistral.ai
MISTRAL_API_KEY=

# Perplexity AI - بحث على الإنترنت + ذكاء اصطناعي
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ====== مزودون مدفوعون / PAID PROVIDERS ======

# OpenAI - GPT-4o, GPT-4-turbo
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic - Claude 3.5 Sonnet (الأفضل للكود)
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# xAI Grok - ذكاء اصطناعي من إيلون ماسك
# https://console.x.ai
XAI_API_KEY=your_api_key

# DeepSeek - نموذج صيني قوي وأرخص بكثير من GPT
# https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ====== إعدادات النظام / SYSTEM SETTINGS ======

# مسار ملفات الذاكرة
MEMORY_PATH=./memory

# أقصى حجم سجل الذاكرة (عدد الإدخالات)
MAX_MEMORY_ENTRIES=10000

# السجل اليومي للتعلم
LEARNING_LOG_PATH=./memory/learning-log.jsonl

# تفعيل التحسين الذاتي التلقائي (true/false)
AUTO_SELF_IMPROVE=true

# فترة التحسين الذاتي بالدقائق
SELF_IMPROVE_INTERVAL=60

# نموذج افتراضي لكل مهمة إذا لم يُحدد
DEFAULT_MODEL=gemini-1.5-flash

# تفعيل وضع التصحيح
DEBUG=false

# ====== Ollama - نماذج محلية مجانية ======
# ثبّت من: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=false
