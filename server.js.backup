const express = require('express');
const cors = require('cors');
const path = require('path');
const fs = require('fs');
const jwt = require('jsonwebtoken');
const bcrypt = require('bcryptjs');

const app = express();
const PORT = process.env.PORT || 3000;

// Middleware
app.use(cors());
app.use(express.json());
app.use(express.urlencoded({ extended: true }));
app.use(express.static('public'));

// قراءة قاعدة البيانات
let db = JSON.parse(fs.readFileSync('data.json', 'utf8'));

// حفظ قاعدة البيانات
function saveDB() {
    fs.writeFileSync('data.json', JSON.stringify(db, null, 2));
}

// JWT Secret
const JWT_SECRET = 'stampbook_super_secret_2026';

// ============= دوال المساعدة =============
function verifyToken(req, res, next) {
    const token = req.headers['authorization']?.split(' ')[1];
    if (!token) return res.status(401).json({ error: 'غير مصرح به' });
    try {
        const decoded = jwt.verify(token, JWT_SECRET);
        req.userId = decoded.id;
        next();
    } catch {
        res.status(401).json({ error: 'توكن غير صالح' });
    }
}

// ============= واجهات API =============

// تسجيل مستخدم جديد
app.post('/api/auth/register', async (req, res) => {
    try {
        const { name, email, password, phone } = req.body;
        
        if (db.users.find(u => u.email === email)) {
            return res.status(400).json({ error: 'البريد الإلكتروني مستخدم بالفعل' });
        }
        
        const hashedPassword = await bcrypt.hash(password, 10);
        const user = {
            id: Date.now().toString(),
            name,
            email,
            phone: phone || '',
            password: hashedPassword,
            walletAddress: '',
            stpBalance: 0,
            nftBalance: 0,
            fiatBalance: 0,
            points: 0,
            createdAt: new Date().toISOString(),
            isVerified: false,
            preferredLanguage: 'ar',
            preferredCurrency: 'USD'
        };
        
        db.users.push(user);
        saveDB();
        
        const token = jwt.sign({ id: user.id, email: user.email }, JWT_SECRET, { expiresIn: '7d' });
        res.json({ 
            success: true, 
            token, 
            user: { id: user.id, name: user.name, email: user.email, stpBalance: 0, points: 0 } 
        });
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

// تسجيل الدخول
app.post('/api/auth/login', async (req, res) => {
    try {
        const { email, password } = req.body;
        const user = db.users.find(u => u.email === email);
        
        if (!user || !(await bcrypt.compare(password, user.password))) {
            return res.status(401).json({ error: 'البريد الإلكتروني أو كلمة المرور غير صحيحة' });
        }
        
        const token = jwt.sign({ id: user.id, email: user.email }, JWT_SECRET, { expiresIn: '7d' });
        res.json({ 
            success: true, 
            token, 
            user: { id: user.id, name: user.name, email: user.email, stpBalance: user.stpBalance, points: user.points } 
        });
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

// الحصول على معلومات المستخدم
app.get('/api/auth/me', verifyToken, (req, res) => {
    const user = db.users.find(u => u.id === req.userId);
    if (user) {
        res.json({ 
            name: user.name, 
            email: user.email, 
            stpBalance: user.stpBalance,
            nftBalance: user.nftBalance,
            fiatBalance: user.fiatBalance,
            points: user.points,
            walletAddress: user.walletAddress
        });
    } else {
        res.status(404).json({ error: 'مستخدم غير موجود' });
    }
});

// تحديث إعدادات المستخدم (اللغة، العملة)
app.post('/api/auth/settings', verifyToken, (req, res) => {
    const { language, currency } = req.body;
    const user = db.users.find(u => u.id === req.userId);
    if (user) {
        if (language) user.preferredLanguage = language;
        if (currency) user.preferredCurrency = currency;
        saveDB();
        res.json({ success: true, language: user.preferredLanguage, currency: user.preferredCurrency });
    } else {
        res.status(404).json({ error: 'مستخدم غير موجود' });
    }
});

// إضافة عملات مكافأة (نقاط)
app.post('/api/points/add', verifyToken, (req, res) => {
    const { points, reason } = req.body;
    const user = db.users.find(u => u.id === req.userId);
    if (user) {
        user.points += points;
        saveDB();
        res.json({ success: true, points: user.points, reason });
    } else {
        res.status(404).json({ error: 'مستخدم غير موجود' });
    }
});

// ============= NFTs =============

// الحصول على جميع NFTs
app.get('/api/nfts', (req, res) => {
    res.json(db.nfts);
});

// إضافة NFT جديد
app.post('/api/nfts/add', verifyToken, (req, res) => {
    const { name, description, imageUrl, price, category } = req.body;
    const nft = {
        id: Date.now().toString(),
        name,
        description,
        imageUrl: imageUrl || 'https://placehold.co/400x300',
        price: parseFloat(price),
        category,
        ownerId: req.userId,
        createdAt: new Date().toISOString()
    };
    db.nfts.push(nft);
    saveDB();
    res.json({ success: true, nft });
});

// شراء NFT
app.post('/api/nfts/buy/:id', verifyToken, (req, res) => {
    const nft = db.nfts.find(n => n.id === req.params.id);
    if (!nft) return res.status(404).json({ error: 'NFT غير موجود' });
    
    const user = db.users.find(u => u.id === req.userId);
    if (user.stpBalance < nft.price) {
        return res.status(400).json({ error: 'رصيد غير كافٍ' });
    }
    
    user.stpBalance -= nft.price;
    user.nftBalance += 1;
    nft.ownerId = req.userId;
    saveDB();
    
    res.json({ success: true, message: 'تم شراء NFT بنجاح', newBalance: user.stpBalance });
});

// ============= المزادات =============

app.get('/api/auctions', (req, res) => {
    res.json(db.auctions);
});

app.post('/api/auctions/create', verifyToken, (req, res) => {
    const { title, description, startingPrice, endTime, imageUrl } = req.body;
    const auction = {
        id: Date.now().toString(),
        title,
        description,
        startingPrice: parseFloat(startingPrice),
        currentPrice: parseFloat(startingPrice),
        endTime,
        imageUrl: imageUrl || 'https://placehold.co/400x300',
        creatorId: req.userId,
        bids: [],
        status: 'active',
        createdAt: new Date().toISOString()
    };
    db.auctions.push(auction);
    saveDB();
    res.json({ success: true, auction });
});

app.post('/api/auctions/bid/:id', verifyToken, (req, res) => {
    const { amount } = req.body;
    const auction = db.auctions.find(a => a.id === req.params.id);
    if (!auction) return res.status(404).json({ error: 'مزاد غير موجود' });
    if (amount <= auction.currentPrice) return res.status(400).json({ error: 'العرض يجب أن يكون أكبر من السعر الحالي' });
    
    auction.bids.push({ userId: req.userId, amount, time: new Date().toISOString() });
    auction.currentPrice = amount;
    saveDB();
    res.json({ success: true, currentPrice: auction.currentPrice });
});

// ============= الأخبار والأحداث =============

app.get('/api/news', (req, res) => {
    const news = [
        { id: 1, title: '🚀 إطلاق منصة Stampbook رسمياً', date: '2026-04-01', category: 'إطلاق', content: 'أول منصة عربية متكاملة للطوابع الرقمية' },
        { id: 2, title: '🏆 الوبيل الذهبي - أولمبيا ميونخ 2026', date: '2026-08-15', category: 'حدث', content: 'حدث عالمي للطوابع الأولمبية' },
        { id: 3, title: '🤝 شراكة مع Deutsche Post', date: '2026-03-28', category: 'شراكة', content: 'توفير طوابع ألمانية رسمية' },
        { id: 4, title: '💰 إطلاق عملة STP', date: '2026-04-15', category: 'عملة', content: 'سعر الإطلاق 0.20 دولار' }
    ];
    res.json(news);
});

app.get('/api/events', (req, res) => {
    const events = [
        { id: 1, title: 'الوبيل الذهبي', location: 'أولمبيا ميونخ', date: '2026-08-01', description: 'أكبر حدث للطوابع في العالم' },
        { id: 2, title: 'معرض الشارقة للطوابع', location: 'الشارقة', date: '2026-10-15', description: 'معرض إقليمي للطوابع النادرة' }
    ];
    res.json(events);
});

// ============= عملات الموقع =============

app.post('/api/buy-stp', verifyToken, (req, res) => {
    const { amount, currency } = req.body;
    const rates = { USD: 0.20, EUR: 0.22, SAR: 0.053, AED: 0.054, EGP: 0.004 };
    const priceInUSD = amount * (rates[currency] || 0.20);
    const stpAmount = priceInUSD / 0.20;
    
    const user = db.users.find(u => u.id === req.userId);
    user.stpBalance += stpAmount;
    user.fiatBalance -= amount;
    saveDB();
    
    res.json({ success: true, stpAmount, newBalance: user.stpBalance });
});

// ============= الحالة العامة =============

app.get('/api/status', (req, res) => {
    res.json({
        status: 'online',
        version: '3.0.0',
        users: db.users.length,
        nfts: db.nfts.length,
        auctions: db.auctions.length
    });
});

