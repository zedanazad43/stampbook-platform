# ─────────────────────────────────────────────────────────────
# Stampbook Platform — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# Security — CHANGE THESE before going to production
JWT_SECRET=replace-with-a-long-random-secret
SYNC_TOKEN=replace-with-another-long-random-secret

# CORS (comma-separated, leave blank to allow all origins in development)
# ALLOWED_ORIGINS=https://ecostamp.net,https://www.ecostamp.net

# Blockchain (optional — for on-chain features)
# STP_CONTRACT_ADDRESS=0xeB834351Ee83b3877DD8620e552652733710d4e1
