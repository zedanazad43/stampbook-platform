{
  "name": "stampcoin-platform",
  "version": "1.0.0",
  "description": "Stampcoin Platform - blockchain-powered digital stamps, wallet and marketplace",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "mkdir -p public && echo 'Static site ready for deployment'",
    "test": "echo 'Tests can be configured'",
    "lint": "echo 'Linting can be configured'",
    "docker:build": "docker build -t stampcoin-platform .",
    "docker:run": "docker run -p 10000:10000 stampcoin-platform",
    "selfhost:up": "docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml up -d --build",
    "selfhost:down": "docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml down",
    "selfhost:logs": "docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml logs -f",
    "agent": "node src/ai-agent-expert/index.js",
    "agent-dev": "node src/ai-agent-expert/index.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  }
}
