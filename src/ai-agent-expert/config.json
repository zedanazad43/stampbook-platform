{
    "agent": {
        "name": "STP Agent Expert",
        "version": "1.0.0",
        "description": "AI-powered agent for Stampcoin Platform project management and optimization",
        "capabilities": [
            "code-analysis",
            "bug-fixing",
            "project-organization",
            "performance-optimization",
            "security-audit",
            "documentation-generation",
            "test-creation"
        ]
    },
    "settings": {
        "autoAnalysis": true,
        "securityScanFrequency": "daily",
        "performanceMonitoring": true,
        "documentationAutoUpdate": false,
        "testCoverageTarget": 80,
        "codeQualityThreshold": 85
    },
    "priorities": {
        "high": ["security", "critical-bugs"],
        "medium": ["performance", "code-quality", "documentation"],
        "low": ["refactoring", "optimization"]
    },
    "api": {
        "version": "v1",
        "endpoints": {
            "status": "/agent/status",
            "activate": "/agent/activate",
            "deactivate": "/agent/deactivate",
            "analyzeCode": "/agent/analyze-code",
            "fixIssues": "/agent/fix-issues",
            "organizeProject": "/agent/organize-project",
            "optimizePerformance": "/agent/optimize-performance",
            "auditSecurity": "/agent/audit-security",
            "generateDocs": "/agent/generate-docs",
            "createTests": "/agent/create-tests"
        }
    },
    "integrations": {
        "github": {
            "enabled": true,
            "webhooks": ["push", "pull_request"],
            "autoReview": true
        },
        "slack": {
            "enabled": false,
            "notifications": ["critical", "high"]
        },
        "email": {
            "enabled": false,
            "recipients": ["dev-team@example.com"]
        }
    }
}